<keymap version="1" name="VSCode 副本" parent="VSCode">
  <action id="$Cut">
    <keyboard-shortcut first-keystroke="ctrl x" />
  </action>
  <action id="CloseContent">
    <keyboard-shortcut first-keystroke="ctrl f4" />
  </action>
  <action id="Debug">
    <keyboard-shortcut first-keystroke="shift f10" />
  </action>
  <action id="DebugClass">
    <keyboard-shortcut first-keystroke="f5" />
  </action>
  <action id="EditorDeleteLine">
    <keyboard-shortcut first-keystroke="shift ctrl k" />
    <keyboard-shortcut first-keystroke="shift delete" />
  </action>
  <action id="EditorDeleteToWordStart">
    <keyboard-shortcut first-keystroke="ctrl back_space" />
    <keyboard-shortcut first-keystroke="ctrl w" />
  </action>
  <action id="EditorDuplicateLines">
    <keyboard-shortcut first-keystroke="shift alt down" />
  </action>
  <action id="EditorIndentSelection" />
  <action id="EditorReverseLines">
    <keyboard-shortcut first-keystroke="ctrl k" second-keystroke="shift r" />
  </action>
  <action id="NextParameter">
    <keyboard-shortcut first-keystroke="tab" />
    <keyboard-shortcut first-keystroke="enter" />
  </action>
  <action id="NextTemplateVariable">
    <keyboard-shortcut first-keystroke="enter" />
    <keyboard-shortcut first-keystroke="tab" />
  </action>
  <action id="PrevParameter">
    <keyboard-shortcut first-keystroke="shift tab" />
    <keyboard-shortcut first-keystroke="shift enter" />
  </action>
  <action id="PreviousTemplateVariable">
    <keyboard-shortcut first-keystroke="shift tab" />
    <keyboard-shortcut first-keystroke="shift enter" />
  </action>
  <action id="Run">
    <keyboard-shortcut first-keystroke="shift ctrl f10" />
  </action>
  <action id="RunClass">
    <keyboard-shortcut first-keystroke="shift ctrl f10" />
    <keyboard-shortcut first-keystroke="ctrl f5" />
  </action>
</keymap>